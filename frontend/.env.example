# Copy to .env only when you need to override the default.
#
# Local dev: leave VITE_API_BASE_URL unset. The app uses "/api" and Vite proxies to Spring Boot
# on port 9000 (see vite.config.js). Do NOT set http://127.0.0.1:9000 here — that bypasses the proxy.
#
# Point at a remote API (staging / production):
# VITE_API_BASE_URL=https://your-api.example.com
